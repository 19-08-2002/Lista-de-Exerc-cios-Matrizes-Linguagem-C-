#include <stdio.h>

int main() {
    int matriz[3][3];
    int i, j;
    int pares = 0;

    printf("Digite os valores da matriz 3x3:\n");

    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            scanf("%d", &matriz[i][j]);

            if(matriz[i][j] % 2 == 0) {
                pares++;
            }
        }
    }

    printf("Quantidade de numeros pares: %d\n", pares);

    return 0;
}
