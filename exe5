#include <stdio.h>

int main() {
    int matriz[3][3];
    int i, j;
    int soma;

    printf("Digite os valores da matriz 3x3:\n");

    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            scanf("%d", &matriz[i][j]);
        }
    }

    for(j = 0; j < 3; j++) {
        soma = 0;

        for(i = 0; i < 3; i++) {
            soma += matriz[i][j];
        }

        printf("Soma da coluna %d: %d\n", j, soma);
    }

    return 0;
}
